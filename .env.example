# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required — get a free token at https://huggingface.co/settings/tokens
# Make sure "Make calls to Inference Providers" is enabled for the token.
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — override the default models / provider
# HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2
# HF_FAST_MODEL=microsoft/Phi-3-mini-4k-instruct
# HF_PROVIDER=featherless-ai

# Optional — Slack integration (see README "Integration Setup")
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# Optional — Google Sheets integration (see README "Integration Setup")
# GOOGLE_SHEET_ID=your_sheet_id_here
# GOOGLE_CREDENTIALS_PATH=credentials/google_credentials.json
